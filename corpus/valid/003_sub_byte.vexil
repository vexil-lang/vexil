# §3.2: Sub-byte types — valid N ranges.
# uN: 1 ≤ N ≤ 64, N ∉ {8,16,32,64}
# iN: 2 ≤ N ≤ 64, N ∉ {8,16,32,64}
namespace test.sub_byte

message SubByteUnsigned {
    a @0 : u1
    b @1 : u2
    c @2 : u3
    d @3 : u4
    e @4 : u5
    f @5 : u6
    g @6 : u7
    h @7 : u9
    i @8 : u15
    j @9 : u17
    k @10 : u31
    l @11 : u33
    m @12 : u63
}

message SubByteSigned {
    a @0 : i2
    b @1 : i3
    c @2 : i4
    d @3 : i5
    e @4 : i6
    f @5 : i7
    g @6 : i9
    h @7 : i15
    i @8 : i17
    j @9 : i31
    k @10 : i33
    l @11 : i63
}
