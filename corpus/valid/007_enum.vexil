# §4.2: Enums — basic, exhaustive, non-exhaustive, explicit backing type.
namespace test.enums

enum Direction {
    North @0
    South @1
    East  @2
    West  @3
}

@non_exhaustive
enum ClientKind {
    Renderer @0
    Agent    @1
    Plugin   @2
    Shell    @3
}

# Explicit backing type
enum HardwareStatus : u16 {
    Ok    @0
    Warn  @1
    Fault @2
}

# Large ordinal values
enum Sparse : u32 {
    Low  @0
    High @1000
}

# Tombstone in enum
enum Lifecycle {
    Active  @0
    @removed(1, reason: "Replaced by Suspended")
    Pending @2
}
