namespace test.geom

message Transform {
    pos @0 : vec3<fixed64>
    rot @1 : quat<fixed64>
    gl_pos @2 : vec3<f32>
    model @3 : mat4<f32>
}

message Vectors {
    v2 @0 : vec2<f64>
    v3 @1 : vec3<f32>
    v4 @2 : vec4<fixed32>
}

message Matrices {
    m3 @0 : mat3<f64>
    m4 @1 : mat4<f32>
}
