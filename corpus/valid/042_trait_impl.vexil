namespace test.traits

trait SensorData {
    sensor_id @0 : u32
    timestamp @1 : u64
}

trait Validatable {
    fn validate() -> bool
}

trait Tagged {
    tag @0 : string
    label @1 : string
}

message TemperatureReading {
    sensor_id @0 : u32
    timestamp @1 : u64
    value @2 : fixed32
}

impl SensorData for TemperatureReading { }

message TaggedItem {
    tag @0 : string
    label @1 : string
    data @2 : bytes
}

impl Tagged for TaggedItem { }
