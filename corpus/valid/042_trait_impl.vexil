# Trait/impl system test - minimal version
# Parser doesn't support functions in impl blocks yet

namespace test.trait_impl

# Trait for timestamped messages
trait Timestamped {
    timestamp @1 : u64
}

# Event with timestamp
message Event {
    timestamp @1 : u64
    payload @2 : string
}

# Impl of Timestamped for Event (empty - structural conformance only)
impl Timestamped for Event
