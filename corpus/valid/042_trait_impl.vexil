// Trait/impl system test

namespace test.trait_impl;

/// Trait for timestamped messages
trait Timestamped {
    @1 timestamp: u64;

    fn get_timestamp() -> u64;
}

/// Event with timestamp
message Event {
    @1 timestamp: u64;
    @2 data: bytes;
}

/// Impl of Timestamped for Event
impl Timestamped for Event {
    fn get_timestamp() -> u64;
}
