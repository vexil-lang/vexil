# Trait/impl system test with function declarations

namespace test.trait_impl

# Trait for timestamped messages
trait Timestamped {
    timestamp @1 : u64
    
    fn get_timestamp() -> u64
}

# Event with timestamp
message Event {
    timestamp @1 : u64
    payload @2 : string
}

# Impl of Timestamped for Event with function implementation
impl Timestamped for Event {
    fn get_timestamp() -> u64
}
