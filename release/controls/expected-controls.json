    {"id": "EC-010", "authorityClass": "revocation", "provider": "github", "scope": "provider-backed revocation paths", "expectedState": "A safe, target-scoped non-production or reviewed reversible revocation path proves denial and recovery without a production release effect.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/environments", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"}
