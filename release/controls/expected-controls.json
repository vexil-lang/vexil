  "assertions": [
    {"id": "EC-001", "authorityClass": "branch-protection", "provider": "github", "scope": "branch:main", "expectedState": "Reviewed pull requests and designated required checks are required; force push and deletion are denied.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/branches/main/protection", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
    {"id": "EC-002", "authorityClass": "tag-protection", "provider": "github", "scope": "Canonical Tag namespaces", "expectedState": "Unauthorized creation and every update or deletion attempt are denied; Historical Tags remain untouched.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/rulesets", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
    {"id": "EC-003", "authorityClass": "release-protection", "provider": "github", "scope": "future GitHub releases", "expectedState": "Future releases are immutable without rewriting any historical release or tag.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/releases", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
    {"id": "EC-004", "authorityClass": "environment", "provider": "github", "scope": "target-isolated privileged environments", "expectedState": "Each privileged target has an isolated protected environment with reviewer, self-review, bypass, and wait controls observed.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/environments", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
    {"id": "EC-005", "authorityClass": "workflow-permission", "provider": "github", "scope": "Actions default workflow token permissions", "expectedState": "No implicit write-all default; advisory and rehearsal jobs lack privileged authority.", "query": {"method": "GET", "path": "/repos/vexil-lang/vexil/actions/permissions/workflow", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
