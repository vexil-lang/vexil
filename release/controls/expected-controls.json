    {"id": "EC-008", "authorityClass": "identity-custody", "provider": "npm", "scope": "exact approved npm package identity", "expectedState": "Trusted publisher binds the exact package, repository, workflow, and protected environment with no cross-target credential.", "query": {"method": "GET", "path": "/-/npm/v1/security/trusted-publisher/{exact-approved-package}", "mode": "read-only"}, "severity": "critical", "owner": {"actorId": "github:furkanmamuk", "roleId": "repository-administrator", "assignmentId": "assignment-repository-administrator-2026-07-14"}, "freshness": "fresh-authoritative-observation-required", "publicationEffect": "unknown-or-noncompliant-blocks-manifest-approval-and-privileged-publication"},
