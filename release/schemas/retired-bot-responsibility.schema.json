{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vexil.dev/release/schemas/retired-bot-responsibility.schema.json",
  "title": "Vexil Retired-Bot Responsibility Inventory",
  "description": "Canonical, source-attributed public inventory of responsibilities formerly represented by retired bot configuration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "$id", "inventorySchema", "version", "historicalConfiguration", "manifestComparison", "responsibilities", "normalization"],
  "properties": {
    "$schema": {"const": "https://json-schema.org/draft/2020-12/schema"},
    "$id": {"const": "https://vexil.dev/release/stewardship/responsibilities.json"},
    "inventorySchema": {"const": "https://vexil.dev/release/schemas/retired-bot-responsibility.schema.json"},
    "version": {"const": "1.0"},
    "historicalConfiguration": {"$ref": "#/$defs/historicalConfiguration"},
    "manifestComparison": {"$ref": "#/$defs/manifestComparison"},
    "responsibilities": {"type": "array", "minItems": 9, "items": {"$ref": "#/$defs/responsibility"}},
    "normalization": {"$ref": "#/$defs/normalization"}
  },
  "$defs": {
    "evidence": {"type": "object", "additionalProperties": false, "required": ["source", "observedBehavior"], "properties": {"source": {"type": "string"}, "observedBehavior": {"type": "string"}}},
    "historicalConfiguration": {"type": "object", "additionalProperties": false, "required": ["source", "status", "nonAuthorityStatement"], "properties": {"source": {"const": ".vexilbot.toml"}, "status": {"const": "retired-historical-evidence"}, "nonAuthorityStatement": {"type": "string"}}},
    "manifestComparison": {"type": "object", "additionalProperties": false, "required": ["retiredConfigurationSource", "nonAuthorityStatement", "retiredConfiguredUnits", "publishableManifestUnits", "mismatches"], "properties": {"retiredConfigurationSource": {"const": ".vexilbot.toml"}, "nonAuthorityStatement": {"type": "string"}, "retiredConfiguredUnits": {"type": "array", "items": {"type": "string"}}, "publishableManifestUnits": {"type": "array", "items": {"type": "string"}}, "mismatches": {"type": "array", "items": {"$ref": "#/$defs/mismatch"}}}},
    "mismatch": {"type": "object", "additionalProperties": false, "required": ["id", "unit", "kind", "observedBehavior"], "properties": {"id": {"type": "string"}, "unit": {"type": "string"}, "kind": {"type": "string"}, "observedBehavior": {"type": "string"}}},
    "responsibility": {"type": "object", "additionalProperties": false, "required": ["id", "responsibilityClass", "description", "privilegeClass", "historicalEvidence", "affectedSurfaces", "failureImpact", "decisionOwner", "dispositionStatus"], "properties": {"id": {"type": "string"}, "responsibilityClass": {"enum": ["release-preparation", "dependency-ordering", "tagging", "publication", "triage", "labeling", "welcome-messaging", "policy-warnings", "manual-fallback-knowledge"]}, "description": {"type": "string"}, "privilegeClass": {"enum": ["advisory", "privileged", "policy"]}, "historicalEvidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}}, "affectedSurfaces": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "failureImpact": {"type": "string"}, "decisionOwner": {"type": "string"}, "dispositionStatus": {"enum": ["undispositioned", "maintained-replacement", "owned-manual-procedure", "approved-retirement", "owned-fail-closed-procedure"]}, "advisoryDisposition": {"$ref": "#/$defs/advisoryDisposition"}, "privilegedDispositionId": {"type": "string", "minLength": 1}}, "allOf": [{"if": {"properties": {"privilegeClass": {"const": "advisory"}}}, "then": {"required": ["advisoryDisposition"], "properties": {"dispositionStatus": {"enum": ["maintained-replacement", "owned-manual-procedure", "approved-retirement"]}}, "not": {"required": ["privilegedDispositionId"]}}, "else": {"required": ["privilegedDispositionId"], "properties": {"dispositionStatus": {"const": "owned-fail-closed-procedure"}}, "not": {"required": ["advisoryDisposition"]}}}]},
    "assignmentReference": {"type": "object", "additionalProperties": false, "required": ["actorId", "roleId", "assignmentId"], "properties": {"actorId": {"pattern": "^github:"}, "roleId": {"enum": ["release-steward", "repository-administrator", "security-steward", "package-steward", "release-run-coordinator"]}, "assignmentId": {"type": "string", "minLength": 1}}},
    "permissionIntent": {"enum": ["repository-metadata:read", "issues:read", "issues:write", "discussions:read", "discussions:write", "pull-requests:read", "pull-requests:write"]},
    "fallback": {"type": "object", "additionalProperties": false, "required": ["decision", "owner", "evidenceDestination", "noPrivilegeBoundary"], "properties": {"decision": {"enum": ["perform-manually", "defer"]}, "owner": {"$ref": "#/$defs/assignmentReference"}, "evidenceDestination": {"type": "string", "minLength": 1}, "noPrivilegeBoundary": {"type": "string", "minLength": 1}}},
    "advisoryDisposition": {"type": "object", "additionalProperties": false, "required": ["kind", "owner", "rationale", "minimumPermissions", "auditEvidence", "failureBehavior", "fallback", "nonAuthorityBoundary"], "properties": {"kind": {"enum": ["maintained-replacement", "owned-manual-procedure", "approved-retirement"]}, "owner": {"$ref": "#/$defs/assignmentReference"}, "rationale": {"type": "string", "minLength": 1}, "minimumPermissions": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/permissionIntent"}}, "auditEvidence": {"type": "string", "minLength": 1}, "failureBehavior": {"type": "string", "minLength": 1}, "fallback": {"$ref": "#/$defs/fallback"}, "nonAuthorityBoundary": {"type": "string", "minLength": 1}, "automation": {"type": "object", "additionalProperties": false, "required": ["source", "deploymentState", "trigger", "inputs", "permissionIntents", "auditSurface", "noLiveEffects"], "properties": {"source": {"type": "string", "minLength": 1}, "deploymentState": {"const": "not-deployed"}, "trigger": {"type": "string", "minLength": 1}, "inputs": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "permissionIntents": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/permissionIntent"}}, "auditSurface": {"type": "string", "minLength": 1}, "noLiveEffects": {"const": true}}}, "manualProcedure": {"type": "object", "additionalProperties": false, "required": ["decision", "evidenceDestination", "noPrivilegeBoundary"], "properties": {"decision": {"const": "perform-or-defer-manually"}, "evidenceDestination": {"type": "string", "minLength": 1}, "noPrivilegeBoundary": {"type": "string", "minLength": 1}}}, "retirement": {"type": "object", "additionalProperties": false, "required": ["publicDecision", "lostBehavior", "impact", "residualRisk", "approverActorId"], "properties": {"publicDecision": {"type": "object", "additionalProperties": false, "required": ["id", "source", "status"], "properties": {"id": {"type": "string", "minLength": 1}, "source": {"type": "string", "minLength": 1}, "status": {"const": "accepted"}}}, "lostBehavior": {"type": "string", "minLength": 1}, "impact": {"type": "string", "minLength": 1}, "residualRisk": {"type": "string", "minLength": 1}, "approverActorId": {"pattern": "^github:"}}}}, "oneOf": [{"properties": {"kind": {"const": "maintained-replacement"}}, "required": ["automation"], "not": {"anyOf": [{"required": ["manualProcedure"]}, {"required": ["retirement"]}]}}, {"properties": {"kind": {"const": "owned-manual-procedure"}}, "required": ["manualProcedure"], "not": {"anyOf": [{"required": ["automation"]}, {"required": ["retirement"]}]}}, {"properties": {"kind": {"const": "approved-retirement"}}, "required": ["retirement"], "not": {"anyOf": [{"required": ["automation"]}, {"required": ["manualProcedure"]}]}}]},
    "normalization": {"type": "object", "additionalProperties": false, "required": ["ordering", "duplicatePolicy"], "properties": {"ordering": {"const": "stable-id-ascending"}, "duplicatePolicy": {"const": "reject-conflicting-duplicates"}}}
  }
}
