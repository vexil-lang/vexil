{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vexil.dev/release/schemas/revocation-exercise.schema.json",
  "title": "Vexil Safe Revocation Exercise Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "$id", "exerciseSchema", "version", "recordId", "recordKind", "status", "scope", "safetyBoundary", "participants", "events", "evidence", "publicationReadiness"],
  "properties": {
    "$schema": {"const": "https://json-schema.org/draft/2020-12/schema"},
    "$id": {"type": "string"},
    "exerciseSchema": {"const": "https://vexil.dev/release/schemas/revocation-exercise.schema.json"},
    "version": {"const": "1.0"},
    "recordId": {"type": "string", "pattern": "^REV-"},
    "recordKind": {"enum": ["revocation-exercise-plan", "revocation-exercise-result"]},
    "status": {"enum": ["blocked-unexecuted", "unexecuted", "approved", "executed-success", "executed-failed"]},
    "scope": {"type": "string", "minLength": 1},
    "safetyBoundary": {"$ref": "#/$defs/boundary"},
    "participants": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/participant"}},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "evidence": {"$ref": "#/$defs/evidence"},
    "publicationReadiness": {"const": "blocked"}
  },
  "allOf": [
    {
      "if": {"properties": {"recordKind": {"const": "revocation-exercise-plan"}}, "required": ["recordKind"]},
      "then": {"properties": {"status": {"enum": ["blocked-unexecuted", "approved"]}}}
    },
    {
      "if": {"properties": {"recordKind": {"const": "revocation-exercise-result"}}, "required": ["recordKind"]},
      "then": {"properties": {"status": {"enum": ["unexecuted", "executed-success", "executed-failed"]}}}
    },
    {
      "if": {"properties": {"recordKind": {"const": "revocation-exercise-result"}, "status": {"const": "executed-success"}}, "required": ["recordKind", "status"]},
      "then": {"properties": {"events": {"minItems": 12}, "evidence": {"required": ["stableEvidenceDigest"]}}}
    }
  ],
  "$defs": {
    "boundary": {"type": "object", "additionalProperties": false, "required": ["target", "requiredPrecondition", "prohibitedEffects", "stopCondition"], "properties": {"target": {"const": "approved-non-production-test-identity-or-individually-reviewed-reversible-path"}, "requiredPrecondition": {"type": "string"}, "prohibitedEffects": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "stopCondition": {"type": "string"}}},
    "participant": {"type": "object", "additionalProperties": false, "required": ["actorId", "assertedRole", "assignmentId"], "properties": {"actorId": {"const": "github:furkanmamuk"}, "assertedRole": {"const": "repository-administrator"}, "assignmentId": {"const": "assignment-repository-administrator-2026-07-14"}}},
    "event": {"type": "object", "additionalProperties": false, "required": ["eventId", "atUtc", "targetSlot", "action", "outcome", "providerMethod", "providerReference"], "properties": {"eventId": {"type": "string", "pattern": "^REV-EVENT-"}, "atUtc": {"type": "string", "format": "date-time"}, "targetSlot": {"enum": ["key-a", "key-b"]}, "action": {"enum": ["preflight-absence", "created", "authenticated", "revoked", "denied", "metadata-absent"]}, "outcome": {"type": "string", "minLength": 1}, "providerMethod": {"enum": ["GET", "POST", "DELETE", "SSH"]}, "providerReference": {"type": "string", "minLength": 1}, "keyId": {"type": "integer", "minimum": 1}, "keyFingerprint": {"type": "string", "pattern": "^SHA256:[A-Za-z0-9_+=/-]+$"}}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["secretsIncluded", "providerAuditReference", "outcome"], "properties": {"secretsIncluded": {"const": false}, "providerAuditReference": {"type": "string"}, "outcome": {"type": "string"}, "stableEvidenceDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}}
  }
}
