{
  "name": "@vexil/runtime",
  "version": "0.4.0",
  "description": "Runtime support for Vexil generated code — bit-level I/O and wire encoding primitives",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vexil-lang/vexil",
    "directory": "packages/runtime-ts"
  },
  "homepage": "https://github.com/vexil-lang/vexil/tree/main/packages/runtime-ts",
  "bugs": "https://github.com/vexil-lang/vexil/issues",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["vexil", "schema", "serialization", "binary", "protocol", "bitpack", "codec"],
  "license": "MIT OR Apache-2.0"
}
